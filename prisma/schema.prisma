generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL")
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  phone         String        @unique
  pin           String
  accountNumber String        @unique
  profileImage  String?       // base64 data URI or remote URL, user-uploaded avatar
  address       String?

  // Premium profile / KYC-lite details
  dateOfBirth     DateTime?
  gender          String?
  occupation      String?
  nationality     String?
  maritalStatus   String?
  nextOfKinName   String?
  nextOfKinPhone  String?
  bvn             String?  // stored masked/last-4 only from the client; no real BVN verification provider is wired up
  kycTier         Int      @default(1)

  // Referrals
  referralCode  String   @unique
  referredBy    String?  // the referralCode of whoever invited this user, if any

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  wallet        Wallet?
  transactions  Transaction[]
  savingsGoals  SavingsGoal[]
  loans         Loan[]
  cards         Card[]
  invoices      Invoice[]
  budgets       Budget[]
  disputes      Dispute[]
}

model Dispute {
  id            String   @id @default(uuid())
  userId        String
  transactionId String
  reason        String
  details       String?
  status        String   @default("open") // open | under_review | resolved | rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id           String   @id @default(uuid())
  userId       String
  category     String   // e.g. "Transfers", "Bills & Utilities", "Airtime", "Savings"
  monthlyLimit Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  type      String
  category  String
  title     String
  subtitle  String
  amount    Decimal  @db.Decimal(10, 2)
  bank      String?  // <-- GAP C: Added bank field for external transfers
  recipientAccount String? // the identifier (account number OR phone) the sender targeted — powers the Transfer screen's "Recent" list
  status    String   @default("completed")
  reference String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsGoal {
  id        String   @id @default(uuid())
  userId    String
  name      String
  target    Decimal  @db.Decimal(10, 2)
  saved     Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Loan {
  id           String   @id @default(uuid())
  userId       String
  principal    Decimal  @db.Decimal(10, 2)
  fee          Decimal  @db.Decimal(10, 2)
  totalOwed    Decimal  @db.Decimal(10, 2)
  amountRepaid Decimal  @default(0.00) @db.Decimal(10, 2)
  termDays     Int
  dueDate      DateTime
  repaid       Boolean  @default(false)
  issuedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// <-- GAP E: NEW MODULES -->
model Card {
  id         String   @id @default(uuid())
  userId     String
  cardNumber String   @unique
  expiry     String
  cvv        String
  type       String   @default("VIRTUAL")
  isFrozen   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String   @id @default(uuid())
  userId      String
  clientName  String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  status      String   @default("issued")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
